---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="not-found">
    <div class="nf-glow" aria-hidden="true"></div>
    <img src={`${base}astronaut-3d.png`} alt="" class="nf-astronaut" width="180" height="180" aria-hidden="true" />
    <p class="nf-code">404</p>
    <h1>Lost in Space</h1>
    <p class="nf-msg">This page drifted off into the cosmos. Let's get you back to Earth.</p>
    <a href={base} class="btn btn-primary">Back to Home</a>
  </div>
</Layout>

<style>
  .not-found {
    min-height: calc(100dvh - var(--nav-h));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    position: relative;
  }

  .nf-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(6,182,212,0.12) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .nf-astronaut {
    width: 160px;
    height: 160px;
    object-fit: contain;
    filter: drop-shadow(0 0 24px rgba(6,182,212,0.5));
    animation: float 4s ease-in-out infinite;
    margin-bottom: 1.5rem;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-14px); }
  }

  .nf-code {
    font-family: 'Rubik', sans-serif;
    font-size: 7rem;
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, var(--accent), #0891B2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  h1 {
    margin-bottom: 1rem;
  }

  .nf-msg {
    max-width: 380px;
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }
</style>
