---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home" description="ICT Exoticz – Wichita's go-to shop for hemp-derived cannabinoids, stylish apparel, and exotic lifestyle products.">

  <!-- ── Hero ── -->
  <section class="hero">
    <!-- Floating orbs -->
    <div class="hero-orb orb-1" aria-hidden="true"></div>
    <div class="hero-orb orb-2" aria-hidden="true"></div>

    <div class="container hero-content">
      <div class="hero-eyebrow">
        <span class="orbit-dot" aria-hidden="true"></span>
        <span class="section-label" style="margin:0">Wichita, Kansas · Est. ICT</span>
      </div>
      <h1>Welcome to<br /><span class="hero-brand">ICT Exoticz</span></h1>
      <p class="hero-sub">Curated hemp-derived cannabinoids, stylish apparel, and exotic lifestyle products — making luxury accessible to everyone in the ICT.</p>
      <div class="hero-actions">
        <a href={`${base}products`} class="btn btn-primary">Shop Products</a>
        <a href={`${base}locations`} class="btn btn-outline">Find a Location</a>
      </div>
      <p class="hero-notice">
        <span class="notice-dot" aria-hidden="true"></span>
        Must be 21+ to purchase cannabinoid products
      </p>
    </div>

  </section>

  <!-- ── Categories ── -->
  <section class="section">
    <div class="container">
      <span class="section-label">What We Carry</span>
      <h2>Exotic Products for Every Lifestyle</h2>
      <div class="divider"></div>
      <div class="categories-grid">

        <div class="glass-card cat-card">
          <div class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </div>
          <h3>Hemp-Derived Cannabinoids</h3>
          <p>Premium HHC vape cartridges, Delta-9 gummies, HHC oils, and combination products. Lab-tested and responsibly sourced.</p>
          <a href={`${base}products`} class="card-link">View Products &rarr;</a>
        </div>

        <div class="glass-card cat-card">
          <div class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg>
          </div>
          <h3>Apparel & Accessories</h3>
          <p>Stylish clothing and accessories curated to keep you looking sharp. We bring the best exotic fashion finds straight to Wichita.</p>
          <a href={`${base}products`} class="card-link">View Products &rarr;</a>
        </div>

        <div class="glass-card cat-card">
          <div class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3>Lifestyle & Exotic Items</h3>
          <p>Unique exotic items that set you apart. Always updating our inventory with the latest in lifestyle and luxury goods.</p>
          <a href={`${base}products`} class="card-link">View Products &rarr;</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── About ── -->
  <section class="section about-section">
    <div class="container about-inner">
      <div class="about-text">
        <span class="section-label">About Us</span>
        <h2>Wichita's Premier Destination for Exotic Products</h2>
        <div class="divider"></div>
        <p>ICT Exoticz is Wichita's go-to destination for unique and stylish products. We carry a curated selection of exotic items designed to elevate your lifestyle — from premium hemp-derived cannabinoid products to fashion-forward apparel and accessories.</p>
        <p style="margin-top:1rem">With two convenient locations in Wichita, KS, we're here to serve you with knowledgeable staff and a welcoming atmosphere. We believe in making quality products accessible to everyone in the ICT community.</p>
        <a href={`${base}locations`} class="btn btn-outline" style="margin-top:1.75rem">Our Locations</a>
      </div>
      <div class="about-stats">
        <div class="glass-card stat-card">
          <span class="stat-num">2</span>
          <span class="stat-label">Locations</span>
        </div>
        <div class="glass-card stat-card">
          <span class="stat-num">ICT</span>
          <span class="stat-label">Wichita, Kansas</span>
        </div>
        <div class="glass-card stat-card">
          <span class="stat-num">21+</span>
          <span class="stat-label">Age Requirement</span>
        </div>
        <div class="glass-card stat-card accent-stat">
          <span class="stat-num">Lab</span>
          <span class="stat-label">Tested Products</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Locations Preview ── -->
  <section class="section">
    <div class="container">
      <span class="section-label">Find Us</span>
      <h2>Two Wichita Locations</h2>
      <div class="divider"></div>
      <div class="locations-grid">

        <div class="glass-card location-card">
          <div class="loc-header">
            <h3>ICT Exoticz 2</h3>
            <span class="loc-badge">Seneca</span>
          </div>
          <address>3125 S Seneca St<br />Wichita, KS 67217</address>
          <a href="tel:+13163122515" class="loc-phone">(316) 312-2515</a>
          <div class="loc-hours">
            <h4>Hours</h4>
            <ul>
              <li><span>Mon – Sat</span><span>10:00 AM – 8:00 PM</span></li>
              <li><span>Sunday</span><span>12:00 PM – 8:00 PM</span></li>
            </ul>
          </div>
          <a href="https://www.google.com/maps/search/?api=1&query=3125+S+Seneca+St,+Wichita,+KS+67217" target="_blank" rel="noopener" class="btn btn-outline" style="width:100%;justify-content:center">Get Directions</a>
        </div>

        <div class="glass-card location-card">
          <div class="loc-header">
            <h3>ICT Exoticz 3</h3>
            <span class="loc-badge">Sweetbriar</span>
          </div>
          <address>2020 W 21st St<br />Wichita, KS 67203</address>
          <a href="tel:+13162459639" class="loc-phone">(316) 245-9639</a>
          <div class="loc-hours">
            <h4>Hours</h4>
            <ul>
              <li><span>Mon – Sun</span><span>12:00 PM – 10:00 PM</span></li>
            </ul>
          </div>
          <a href="https://www.google.com/maps/search/?api=1&query=2020+W+21st+St,+Wichita,+KS+67203" target="_blank" rel="noopener" class="btn btn-outline" style="width:100%;justify-content:center">Get Directions</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta-section">
    <div class="container">
      <div class="glass-card cta-card">
        <div class="cta-orb" aria-hidden="true"></div>
        <h2>Come See Us In-Store</h2>
        <p>Our inventory is always evolving. Visit one of our two Wichita locations to explore the full selection and get personalized recommendations from our team.</p>
        <a href={`${base}contact`} class="btn btn-primary">Contact Us</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section { padding-block: 5rem; }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .orb-1 {
    width: 500px; height: 500px;
    background: rgba(56, 189, 248, 0.12);
    top: -100px; right: -50px;
    animation: float 16s ease-in-out infinite;
  }
  .orb-2 {
    width: 350px; height: 350px;
    background: rgba(139, 92, 246, 0.1);
    bottom: 50px; left: -80px;
    animation: float 20s ease-in-out infinite reverse;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-18px); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: 5rem;
    max-width: 680px;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .orbit-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 10px var(--accent); }
    50% { opacity: 0.5; box-shadow: 0 0 20px var(--accent-glow); }
  }

  .hero h1 {
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    line-height: 1.0;
    margin-bottom: 1.25rem;
    font-weight: 800;
  }

  .hero-brand {
    background: linear-gradient(135deg, var(--accent) 0%, #a5f3fc 50%, #e0f2fe 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.1rem;
    max-width: 540px;
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .hero-notice {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  .notice-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--danger);
    flex-shrink: 0;
  }


  /* ── Categories ── */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .cat-card { padding: 2rem; }

  .cat-icon {
    width: 50px; height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-dim);
    border: 1px solid rgba(56, 189, 248, 0.25);
    border-radius: var(--radius-sm);
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .cat-card h3 { margin-bottom: 0.65rem; }
  .cat-card p { font-size: 0.9rem; margin-bottom: 1.25rem; }

  .card-link {
    font-family: 'Rubik', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--accent);
    transition: color 0.15s;
  }
  .card-link:hover { color: var(--accent-hover); }

  /* ── About ── */
  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-card {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .stat-num {
    font-family: 'Rubik', sans-serif;
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }

  .accent-stat .stat-num {
    background: linear-gradient(135deg, var(--accent), #a5f3fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  /* ── Locations ── */
  .locations-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .location-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .loc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .loc-badge {
    font-family: 'Rubik', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(56, 189, 248, 0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }

  .location-card address { font-size: 0.9rem; color: var(--text-2); line-height: 1.7; }

  .loc-phone {
    font-family: 'Rubik', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-1);
    transition: color 0.15s;
  }
  .loc-phone:hover { color: var(--accent); }

  .loc-hours h4 { margin-bottom: 0.65rem; }

  .loc-hours ul { display: flex; flex-direction: column; gap: 0.3rem; }

  .loc-hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.83rem;
    color: var(--text-2);
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--glass-border);
  }
  .loc-hours li:last-child { border-bottom: none; }
  .loc-hours li span:first-child { color: var(--text-1); font-weight: 500; }
  .closed { color: var(--text-3) !important; }


  /* ── CTA ── */
  .cta-section { padding-block: 3rem 5rem; }

  .cta-card {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 4rem 2rem;
    max-width: 700px;
    margin-inline: auto;
  }

  .cta-orb {
    position: absolute;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(56,189,248,0.1) 0%, transparent 70%);
    border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .cta-card h2 { margin-bottom: 1rem; position: relative; }
  .cta-card p  { margin-bottom: 2rem; position: relative; max-width: 500px; margin-inline: auto; margin-bottom: 2rem; }
  .cta-card .btn { position: relative; }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .about-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .categories-grid { grid-template-columns: 1fr; }
    .locations-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .section { padding-block: 3.5rem; }
    .hero { min-height: 85vh; }
    .about-stats { grid-template-columns: 1fr 1fr; }
  }
</style>
