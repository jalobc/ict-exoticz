---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="ICT Exoticz – Wichita's go-to shop for hemp-derived cannabinoids, stylish apparel, and exotic lifestyle products.">

  <!-- Hero Section -->
  <section class="hero">
    <h1>Welcome to ICT Exoticz</h1>
    <p class="tagline">Wichita's Go-To Shop for Exotic Lifestyle Products</p>
    <p>Curated hemp-derived cannabinoids, stylish apparel, and accessories — making luxury accessible to everyone.</p>
    <div class="hero-actions">
      <a href="/products">Shop Products</a>
      <a href="/locations">Find a Location</a>
    </div>
  </section>

  <!-- About Section -->
  <section class="about">
    <h2>About Us</h2>
    <p>
      ICT Exoticz is Wichita's premier destination for unique and stylish products. We carry a curated selection
      of exotic items designed to elevate your lifestyle — from premium hemp-derived cannabinoid products to
      fashion-forward apparel and accessories.
    </p>
    <p>
      With two convenient locations in Wichita, KS, we're here to serve you with knowledgeable staff and a
      welcoming atmosphere. We believe in making quality products accessible to everyone in the ICT community.
    </p>
  </section>

  <!-- Product Highlights -->
  <section class="product-highlights">
    <h2>What We Carry</h2>
    <div class="product-grid">
      <div class="product-card">
        <h3>Hemp-Derived Cannabinoids</h3>
        <p>Premium HHC vape cartridges, Delta-9 gummies, HHC oils, and combination cannabinoid products. Lab-tested and sourced responsibly.</p>
      </div>
      <div class="product-card">
        <h3>Apparel & Accessories</h3>
        <p>Stylish clothing and accessories curated to keep you looking sharp. We bring the best exotic fashion finds straight to Wichita.</p>
      </div>
      <div class="product-card">
        <h3>Lifestyle Products</h3>
        <p>Unique exotic items that set you apart. We're always updating our inventory with the latest in lifestyle and luxury goods.</p>
      </div>
    </div>
    <a href="/products">View All Products</a>
  </section>

  <!-- Locations Preview -->
  <section class="locations-preview">
    <h2>Two Wichita Locations</h2>
    <div class="locations-grid">
      <div class="location-card">
        <h3>ICT Exoticz</h3>
        <address>
          2837 N Broadway St #100<br />
          Wichita, KS 67219
        </address>
        <p><a href="tel:+13164131307">(316) 413-1307</a></p>
        <h4>Hours</h4>
        <ul>
          <li>Monday: 4:20 PM – 8:00 PM</li>
          <li>Tuesday: Closed</li>
          <li>Wednesday: 4:20 PM – 8:00 PM</li>
          <li>Thursday: 4:20 PM – 8:00 PM</li>
          <li>Friday: 4:20 PM – 10:00 PM</li>
          <li>Saturday: 1:00 PM – 10:00 PM</li>
          <li>Sunday: Closed</li>
        </ul>
      </div>
      <div class="location-card">
        <h3>ICT Exoticz 2</h3>
        <address>
          3125 S Seneca St<br />
          Wichita, KS 67217
        </address>
        <p><a href="tel:+13163122515">(316) 312-2515</a></p>
        <p><a href="mailto:ICTEXOTICZ2@YAHOO.COM">ICTEXOTICZ2@YAHOO.COM</a></p>
        <h4>Hours</h4>
        <ul>
          <li>Monday – Saturday: 10:00 AM – 8:00 PM</li>
          <li>Sunday: 12:00 PM – 8:00 PM</li>
        </ul>
      </div>
    </div>
    <a href="/locations">Get Directions</a>
  </section>

  <!-- Age Notice -->
  <section class="age-notice">
    <p>Must be 21 or older to purchase hemp-derived cannabinoid products.</p>
  </section>

</Layout>
