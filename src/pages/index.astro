---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home" description="ICT Exoticz – Wichita's go-to shop for hemp-derived cannabinoids and exotic lifestyle products.">

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero-orb orb-1" aria-hidden="true"></div>
    <div class="hero-orb orb-2" aria-hidden="true"></div>

    <div class="container hero-grid">

      <div class="hero-text" style="max-width:680px;margin-inline:auto">
        <div class="hero-eyebrow">
          <span class="orbit-dot" aria-hidden="true"></span>
          <span class="section-label" style="margin:0">Wichita, Kansas · Est. 2024</span>
        </div>
        <h1>Welcome to<br /><span class="hero-brand">ICT Exoticz</span></h1>
        <p class="hero-sub">Curated hemp-derived cannabinoids and exotic lifestyle products — making luxury accessible to everyone in the ICT.</p>
        <div class="hero-actions">
          <a href={`${base}products`} class="btn btn-primary">Shop Products</a>
          <a href={`${base}contact`} class="btn btn-outline">Find a Location</a>
        </div>
        <p class="hero-notice">
          <span class="notice-dot" aria-hidden="true"></span>
          Must be 21+ to purchase cannabinoid products
        </p>
      </div>

    </div>
  </section>

  <!-- ── Daily Deals ── -->
  <section class="section deals-section fade-in">
    <div class="container">
      <span class="section-label">Save Every Day</span>
      <h2>Daily Deals</h2>
      <div class="divider"></div>
      <p class="deals-sub">A new deal every day of the week. Stop in and save.</p>
      <div class="deals-grid">

        <div class="glass-card deal-card" data-days="1,4">
          <span class="today-badge">Today's Deal</span>
          <div class="deal-days">Mon &amp; Thu</div>
          <div class="deal-discount">10% OFF</div>
          <div class="deal-desc">All Edibles</div>
        </div>

        <div class="glass-card deal-card" data-days="2,5">
          <span class="today-badge">Today's Deal</span>
          <div class="deal-days">Tue &amp; Fri</div>
          <div class="deal-discount">10% OFF</div>
          <div class="deal-desc">Flower Sale</div>
        </div>

        <div class="glass-card deal-card" data-days="3,6">
          <span class="today-badge">Today's Deal</span>
          <div class="deal-days">Wed &amp; Sat</div>
          <div class="deal-discount">BOGO</div>
          <div class="deal-desc">Buy 1/8 of Wax, get 1g free — or 10% off</div>
        </div>

        <div class="glass-card deal-card" data-days="0">
          <span class="today-badge">Today's Deal</span>
          <div class="deal-days">Sunday</div>
          <div class="deal-discount">10% OFF</div>
          <div class="deal-desc">All Kratom &amp; THCA Vapes</div>
        </div>

      </div>
    </div>
  </section>

  <script>
    // Highlight today's deal
    const today = new Date().getDay();
    document.querySelectorAll<HTMLElement>('.deal-card').forEach(card => {
      const days = card.dataset.days?.split(',').map(Number) ?? [];
      if (days.includes(today)) card.classList.add('deal-today');
    });

    // Open Now indicators
    const now = new Date();
    const day = now.getDay();
    const hour = now.getHours() + now.getMinutes() / 60;

    document.querySelectorAll<HTMLElement>('.location-card[data-hours]').forEach(card => {
      const hours = JSON.parse(card.dataset.hours!);
      const range: [number, number] | null = hours[String(day)];
      const badge = card.querySelector<HTMLElement>('.open-badge');
      if (!badge) return;
      if (range && hour >= range[0] && hour < range[1]) {
        badge.textContent = 'Open Now';
        badge.classList.add('is-open');
      } else {
        badge.textContent = 'Closed';
        badge.classList.add('is-closed');
      }
    });
  </script>

  <!-- ── Categories ── -->
  <section class="section fade-in">
    <div class="container">
      <span class="section-label">What We Carry</span>
      <h2>Exotic Products for Every Lifestyle</h2>
      <div class="divider"></div>
      <div class="categories-grid">

        <div class="glass-card cat-card">
          <div class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </div>
          <h3>Hemp-Derived Cannabinoids</h3>
          <p>Premium HHC vape cartridges, Delta-9 gummies, HHC oils, and combination products. Lab-tested and responsibly sourced.</p>
          <a href={`${base}products`} class="card-link">View Products &rarr;</a>
        </div>

<div class="glass-card cat-card">
          <div class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3>Lifestyle & Exotic Items</h3>
          <p>Unique exotic items that set you apart. Always updating our inventory with the latest in lifestyle and luxury goods.</p>
          <a href={`${base}products`} class="card-link">View Products &rarr;</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── About ── -->
  <section class="section about-section fade-in">
    <div class="container about-inner">
      <div class="about-text">
        <span class="section-label">About Us</span>
        <h2>Wichita's Premier Destination for Exotic Products</h2>
        <div class="divider"></div>
        <p>ICT Exoticz is Wichita's go-to destination for unique products. We carry a curated selection of exotic items designed to elevate your lifestyle — from premium hemp-derived cannabinoid products to unique lifestyle goods.</p>
        <p style="margin-top:1rem">With three convenient locations in Wichita, KS, we're here to serve you with knowledgeable staff and a welcoming atmosphere. We believe in making quality products accessible to everyone in the ICT community.</p>
        <a href={`${base}contact`} class="btn btn-outline" style="margin-top:1.75rem">Our Locations</a>
      </div>
      <div class="about-stats">
        <div class="glass-card stat-card">
          <span class="stat-num">3</span>
          <span class="stat-label">Locations</span>
        </div>
        <div class="glass-card stat-card">
          <span class="stat-num">ICT</span>
          <span class="stat-label">Wichita, Kansas</span>
        </div>
        <div class="glass-card stat-card">
          <span class="stat-num">21+</span>
          <span class="stat-label">Age Requirement</span>
        </div>
        <div class="glass-card stat-card accent-stat">
          <span class="stat-num">Lab</span>
          <span class="stat-label">Tested Products</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Locations Preview ── -->
  <section class="section fade-in">
    <div class="container">
      <span class="section-label">Find Us</span>
      <h2>Three Wichita Locations</h2>
      <div class="divider"></div>
      <div class="locations-grid">

        <div class="glass-card location-card" data-hours='{"0":[12,20],"1":null,"2":[12,20],"3":[12,20],"4":[12,20],"5":[12,20],"6":[12,20]}'>
          <div class="loc-header">
            <h3>ICT Exoticz</h3>
            <span class="loc-badge">Central Ave</span>
            <span class="open-badge"></span>
          </div>
          <address>2001 E Central Ave<br />Wichita, KS 67214</address>
          <a href="tel:+13164945534" class="loc-phone">(316) 494-5534</a>
          <div class="loc-hours">
            <h4>Hours</h4>
            <ul>
              <li><span>Monday</span><span>Closed</span></li>
              <li><span>Tue – Sun</span><span>12:00 PM – 8:00 PM</span></li>
            </ul>
          </div>
          <a href="https://www.google.com/maps/search/?api=1&query=2001+E+Central+Ave,+Wichita,+KS+67214" target="_blank" rel="noopener" class="btn btn-outline" style="width:100%;justify-content:center">Get Directions</a>
        </div>

        <div class="glass-card location-card" data-hours='{"0":[12,22],"1":[10,22],"2":[10,22],"3":[10,22],"4":[10,22],"5":[10,22],"6":[10,22]}'>
          <div class="loc-header">
            <h3>ICT Exoticz 2</h3>
            <span class="loc-badge">Seneca</span>
            <span class="open-badge"></span>
          </div>
          <address>3125 S Seneca St<br />Wichita, KS 67217</address>
          <a href="tel:+13163122515" class="loc-phone">(316) 312-2515</a>
          <div class="loc-hours">
            <h4>Hours</h4>
            <ul>
              <li><span>Mon – Sat</span><span>10:00 AM – 10:00 PM</span></li>
              <li><span>Sunday</span><span>12:00 PM – 10:00 PM</span></li>
            </ul>
          </div>
          <a href="https://www.google.com/maps/search/?api=1&query=3125+S+Seneca+St,+Wichita,+KS+67217" target="_blank" rel="noopener" class="btn btn-outline" style="width:100%;justify-content:center">Get Directions</a>
        </div>

        <div class="glass-card location-card" data-hours='{"0":[12,22],"1":[12,22],"2":[12,22],"3":[12,22],"4":[12,22],"5":[12,22],"6":[12,22]}'>
          <div class="loc-header">
            <h3>ICT Exoticz 3</h3>
            <span class="loc-badge">Sweetbriar</span>
            <span class="open-badge"></span>
          </div>
          <address>2020 W 21st St<br />Wichita, KS 67203</address>
          <a href="tel:+13162459639" class="loc-phone">(316) 245-9639</a>
          <div class="loc-hours">
            <h4>Hours</h4>
            <ul>
              <li><span>Mon – Sun</span><span>12:00 PM – 10:00 PM</span></li>
            </ul>
          </div>
          <a href="https://www.google.com/maps/search/?api=1&query=2020+W+21st+St,+Wichita,+KS+67203" target="_blank" rel="noopener" class="btn btn-outline" style="width:100%;justify-content:center">Get Directions</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Trust Badges ── -->
  <section class="trust-section">
    <div class="container trust-grid">
      <div class="trust-item">
        <span class="trust-icon">🧪</span>
        <span class="trust-label">Lab Tested</span>
        <span class="trust-sub">All cannabinoid products are third-party lab tested for purity and potency</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🔞</span>
        <span class="trust-label">21+ Only</span>
        <span class="trust-sub">Hemp-derived cannabinoid products require valid ID — no exceptions</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">⚖️</span>
        <span class="trust-label">Farm Bill Compliant</span>
        <span class="trust-sub">All products comply with the 2018 Farm Bill and contain less than 0.3% Delta-9 THC</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🌿</span>
        <span class="trust-label">Hemp-Derived</span>
        <span class="trust-sub">100% hemp-derived cannabinoids, responsibly sourced and carefully curated</span>
      </div>
    </div>
  </section>

  <!-- ── Google Reviews ── -->
  <section class="section review-section fade-in">
    <div class="container">
      <span class="section-label">Share Your Experience</span>
      <h2>Leave Us a Google Review</h2>
      <div class="divider"></div>
      <p class="review-sub">Enjoyed your visit? Help us spread the word by leaving a review for your location.</p>
      <div class="review-grid">

        <a href="https://www.google.com/search?q=ICT+Exoticz+2001+E+Central+Ave+Wichita+KS" target="_blank" rel="noopener" class="glass-card review-card">
          <div class="review-g-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          </div>
          <div class="review-location-name">ICT Exoticz</div>
          <div class="review-address">2001 E Central Ave</div>
          <div class="review-stars" aria-label="Leave a 5-star review">★★★★★</div>
          <span class="review-cta-btn">Write a Review</span>
        </a>

        <a href="https://www.google.com/search?q=ICT+Exoticz+2+3125+S+Seneca+St+Wichita+KS" target="_blank" rel="noopener" class="glass-card review-card">
          <div class="review-g-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          </div>
          <div class="review-location-name">ICT Exoticz 2</div>
          <div class="review-address">3125 S Seneca St</div>
          <div class="review-stars" aria-label="Leave a 5-star review">★★★★★</div>
          <span class="review-cta-btn">Write a Review</span>
        </a>

        <a href="https://www.google.com/search?q=ICT+Exoticz+3+2020+W+21st+St+Wichita+KS" target="_blank" rel="noopener" class="glass-card review-card">
          <div class="review-g-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          </div>
          <div class="review-location-name">ICT Exoticz 3</div>
          <div class="review-address">2020 W 21st St</div>
          <div class="review-stars" aria-label="Leave a 5-star review">★★★★★</div>
          <span class="review-cta-btn">Write a Review</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta-section">
    <div class="container">
      <div class="glass-card cta-card">
        <div class="cta-orb" aria-hidden="true"></div>
        <h2>Come See Us In-Store</h2>
        <p>Our inventory is always evolving. Visit any of our three Wichita locations to explore the full selection and get personalized recommendations from our team.</p>
        <a href={`${base}contact`} class="btn btn-primary">Contact Us</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section { padding-block: 5rem; }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 92vh;
    overflow: hidden;
  }

  .hero-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    min-height: 92vh;
    padding-block: 5rem;
    justify-content: center;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .orb-1 {
    width: 500px; height: 500px;
    background: rgba(6, 182, 212, 0.12);
    top: -100px; right: -50px;
    animation: float 16s ease-in-out infinite;
  }
  .orb-2 {
    width: 350px; height: 350px;
    background: rgba(139, 92, 246, 0.1);
    bottom: 50px; left: -80px;
    animation: float 20s ease-in-out infinite reverse;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-18px); }
  }

  .hero-text {
    position: relative;
    z-index: 1;
    max-width: 680px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .orbit-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 10px var(--accent); }
    50% { opacity: 0.5; box-shadow: 0 0 20px var(--accent-glow); }
  }

  .hero h1 {
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    line-height: 1.0;
    margin-bottom: 1.25rem;
    font-weight: 800;
  }

  .hero-brand {
    background: linear-gradient(135deg, var(--accent) 0%, #A5F3FC 50%, #E0F2FE 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.1rem;
    max-width: 540px;
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .hero-notice {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  .notice-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--danger);
    flex-shrink: 0;
  }


  /* ── Categories ── */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .cat-card { padding: 2rem; }

  .cat-icon {
    width: 50px; height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-dim);
    border: 1px solid rgba(6, 182, 212, 0.25);
    border-radius: var(--radius-sm);
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .cat-card h3 { margin-bottom: 0.65rem; }
  .cat-card p { font-size: 0.9rem; margin-bottom: 1.25rem; }

  .card-link {
    font-family: 'Rubik', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--accent);
    transition: color 0.15s;
  }
  .card-link:hover { color: var(--accent-hover); }

  /* ── About ── */
  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-card {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .stat-num {
    font-family: 'Rubik', sans-serif;
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }

  .accent-stat .stat-num {
    background: linear-gradient(135deg, var(--accent), #A5F3FC);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  /* ── Daily Deals ── */
  .deals-sub {
    color: var(--text-2);
    margin-bottom: 2rem;
  }

  .deals-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .deal-card {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .deal-card:hover {
    transform: translateY(-3px);
  }

  .deal-days {
    font-family: 'Rubik', sans-serif;
    font-size: 0.75rem;
