---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home" description="ICT Exoticz – Wichita's go-to shop for hemp-derived cannabinoids, stylish apparel, and exotic lifestyle products.">

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="glow glow-1"></div>
      <div class="glow glow-2"></div>
    </div>
    <div class="container hero-content">
      <span class="section-label">Wichita, Kansas</span>
      <h1>Welcome to<br /><span class="hero-brand">ICT Exoticz</span></h1>
      <p class="hero-sub">Curated hemp-derived cannabinoids, stylish apparel, and exotic lifestyle products — making luxury accessible to everyone in the ICT.</p>
      <div class="hero-actions">
        <a href={`${base}products`} class="btn btn-primary">Shop Products</a>
        <a href={`${base}locations`} class="btn btn-outline">Find a Location</a>
      </div>
      <p class="hero-notice">Must be 21+ to purchase cannabinoid products</p>
    </div>
  </section>

  <!-- ── What We Carry ── -->
  <section class="section categories">
    <div class="container">
      <span class="section-label">What We Carry</span>
      <h2>Exotic Products for Every Lifestyle</h2>
      <div class="divider"></div>
      <div class="categories-grid">
        <div class="category-card">
          <div class="cat-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3>Hemp-Derived Cannabinoids</h3>
          <p>Premium HHC vape cartridges, Delta-9 gummies, HHC oils, and combination products. Lab-tested and responsibly sourced.</p>
          <a href={`${base}products`} class="card-link">View Products &rarr;</a>
        </div>
        <div class="category-card">
          <div class="cat-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg>
          </div>
          <h3>Apparel & Accessories</h3>
          <p>Stylish clothing and accessories curated to keep you looking sharp. We bring the best exotic fashion finds straight to Wichita.</p>
          <a href={`${base}products`} class="card-link">View Products &rarr;</a>
        </div>
        <div class="category-card">
          <div class="cat-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3>Lifestyle & Exotic Items</h3>
          <p>Unique exotic items that set you apart. We're always updating our inventory with the latest in lifestyle and luxury goods.</p>
          <a href={`${base}products`} class="card-link">View Products &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── About ── -->
  <section class="section about">
    <div class="container about-inner">
      <div class="about-text">
        <span class="section-label">About Us</span>
        <h2>Wichita's Premier Destination for Exotic Products</h2>
        <div class="divider"></div>
        <p>ICT Exoticz is Wichita's go-to destination for unique and stylish products. We carry a curated selection of exotic items designed to elevate your lifestyle — from premium hemp-derived cannabinoid products to fashion-forward apparel and accessories.</p>
        <p class="about-p2">With two convenient locations in Wichita, KS, we're here to serve you with knowledgeable staff and a welcoming atmosphere. We believe in making quality products accessible to everyone in the ICT community.</p>
        <a href={`${base}locations`} class="btn btn-outline" style="margin-top: 1.5rem;">Our Locations</a>
      </div>
      <div class="about-stats">
        <div class="stat-card">
          <span class="stat-num">2</span>
          <span class="stat-label">Locations</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">ICT</span>
          <span class="stat-label">Wichita, Kansas</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">21+</span>
          <span class="stat-label">Age Requirement</span>
        </div>
        <div class="stat-card gold">
          <span class="stat-num">Lab</span>
          <span class="stat-label">Tested Products</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Locations Preview ── -->
  <section class="section locations-preview">
    <div class="container">
      <span class="section-label">Find Us</span>
      <h2>Two Wichita Locations</h2>
      <div class="divider"></div>
      <div class="locations-grid">
        <div class="location-card">
          <div class="loc-header">
            <h3>ICT Exoticz</h3>
            <span class="loc-badge">Broadway</span>
          </div>
          <address>
            2837 N Broadway St #100<br />
            Wichita, KS 67219
          </address>
          <a href="tel:+13164131307" class="loc-phone">(316) 413-1307</a>
          <div class="loc-hours">
            <h4>Hours</h4>
            <ul>
              <li><span>Mon</span><span>4:20 PM – 8:00 PM</span></li>
              <li><span>Tue</span><span class="closed">Closed</span></li>
              <li><span>Wed – Thu</span><span>4:20 PM – 8:00 PM</span></li>
              <li><span>Fri</span><span>4:20 PM – 10:00 PM</span></li>
              <li><span>Sat</span><span>1:00 PM – 10:00 PM</span></li>
              <li><span>Sun</span><span class="closed">Closed</span></li>
            </ul>
          </div>
          <a href="https://www.google.com/maps/search/?api=1&query=2837+N+Broadway+St+%23100,+Wichita,+KS+67219" target="_blank" rel="noopener" class="btn btn-outline" style="width: 100%; justify-content: center;">Get Directions</a>
        </div>

        <div class="location-card">
          <div class="loc-header">
            <h3>ICT Exoticz 2</h3>
            <span class="loc-badge">Seneca</span>
          </div>
          <address>
            3125 S Seneca St<br />
            Wichita, KS 67217
          </address>
          <a href="tel:+13163122515" class="loc-phone">(316) 312-2515</a>
          <div class="loc-hours">
            <h4>Hours</h4>
            <ul>
              <li><span>Mon – Sat</span><span>10:00 AM – 8:00 PM</span></li>
              <li><span>Sunday</span><span>12:00 PM – 8:00 PM</span></li>
            </ul>
          </div>
          <a href="https://www.google.com/maps/search/?api=1&query=3125+S+Seneca+St,+Wichita,+KS+67217" target="_blank" rel="noopener" class="btn btn-outline" style="width: 100%; justify-content: center;">Get Directions</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA Banner ── -->
  <section class="cta-banner">
    <div class="cta-bg" aria-hidden="true">
      <div class="glow glow-3"></div>
    </div>
    <div class="container cta-content">
      <h2>Come See Us In-Store</h2>
      <p>Our inventory is always evolving. Visit one of our two Wichita locations to explore the full selection and get personalized recommendations from our team.</p>
      <a href={`${base}contact`} class="btn btn-gold">Contact Us</a>
    </div>
  </section>

</Layout>

<style>
  .section {
    padding-block: 5rem;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.35;
  }
  .glow-1 {
    width: 600px;
    height: 600px;
    background: var(--accent);
    top: -200px;
    right: -150px;
  }
  .glow-2 {
    width: 400px;
    height: 400px;
    background: var(--gold);
    bottom: -100px;
    left: -100px;
    opacity: 0.2;
  }
  .glow-3 {
    width: 800px;
    height: 400px;
    background: var(--accent);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.2;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: 5rem;
    max-width: 720px;
  }

  .hero h1 {
    font-size: clamp(2.8rem, 7vw, 5rem);
    line-height: 1.05;
    margin-bottom: 1.25rem;
  }

  .hero-brand {
    background: linear-gradient(135deg, var(--accent-light) 0%, var(--gold-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.15rem;
    max-width: 560px;
    margin-bottom: 2rem;
    color: var(--text-2);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .hero-notice {
    font-size: 0.8rem;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  /* ── Categories ── */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .category-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 2rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .category-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-accent);
    transform: translateY(-3px);
  }

  .cat-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-glow);
    border: 1px solid var(--accent);
    border-radius: var(--radius-sm);
    color: var(--accent-light);
    margin-bottom: 1.25rem;
  }

  .category-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.2rem;
  }
  .category-card p {
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
  }

  .card-link {
    font-family: 'Oswald', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-light);
  }
  .card-link:hover { color: var(--gold-light); }

  /* ── About ── */
  .about {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-p2 { margin-top: 1rem; }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: border-color 0.2s;
  }
  .stat-card:hover { border-color: var(--accent); }
  .stat-card.gold:hover { border-color: var(--gold); }

  .stat-num {
    font-family: 'Oswald', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--accent-light);
    line-height: 1;
  }
  .stat-card.gold .stat-num { color: var(--gold-light); }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ── Locations Preview ── */
  .locations-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .location-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .location-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-accent);
  }

  .loc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .loc-badge {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    background: var(--gold-glow);
    border: 1px solid var(--gold);
    padding: 0.25rem 0.6rem;
    border-radius: 100px;
  }

  .location-card address {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.7;
  }

  .loc-phone {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-1);
  }
  .loc-phone:hover { color: var(--accent-light); }

  .loc-hours h4 {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--text-3);
    margin-bottom: 0.75rem;
  }

  .loc-hours ul {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .loc-hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.85rem;
    color: var(--text-2);
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--border);
  }
  .loc-hours li:last-child { border-bottom: none; }

  .loc-hours li span:first-child { color: var(--text-1); font-weight: 500; }
  .closed { color: var(--text-3) !important; }

  /* ── CTA Banner ── */
  .cta-banner {
    position: relative;
    padding-block: 5rem;
    text-align: center;
    overflow: hidden;
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin-inline: auto;
  }

  .cta-content h2 { margin-bottom: 1rem; }
  .cta-content p { margin-bottom: 2rem; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .about-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .categories-grid { grid-template-columns: 1fr; }
    .locations-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .section { padding-block: 3.5rem; }
    .hero { min-height: 80vh; }
    .about-stats { grid-template-columns: 1fr 1fr; }
  }
</style>
