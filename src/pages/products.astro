---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const cannabinoidProducts = [
  { name: 'THCA Vapes', description: 'High-potency THCA vape cartridges in a wide range of strains. Smooth hits with lab-tested purity.', tag: 'Popular', icon: '💨' },
  { name: 'HHC Vape Cartridges', description: 'Premium HHC vape cartridges in a variety of strains and flavors. Consistent and clean.', tag: null, icon: '🌿' },
  { name: 'Delta-9 Gummies', description: 'Delicious hemp-derived Delta-9 THC gummies. Precisely dosed and made with quality ingredients.', tag: 'Fan Favorite', icon: '🍬' },
  { name: 'Edibles', description: 'A rotating selection of hemp-derived edibles including gummies, chocolates, and more. Ask about Monday & Thursday deals.', tag: null, icon: '🍫' },
  { name: 'Flower', description: 'Premium hemp flower in a variety of strains. Perfect for those who prefer the traditional experience.', tag: null, icon: '🌸' },
  { name: 'Wax & Concentrates', description: 'Top-shelf wax and concentrates for the experienced consumer. Ask about our Wednesday & Saturday BOGO deal.', tag: 'BOGO Deal', icon: '⚗️' },
  { name: 'Kratom', description: 'Quality kratom products in multiple strains and formats. Ask our knowledgeable staff for guidance.', tag: null, icon: '🍵' },
  { name: 'HHC Oil', description: 'High-quality HHC oil for versatile use. Easy to dose and great for those who prefer a different method.', tag: null, icon: '💧' },
];

const lifestyleProducts = [
  { name: 'Nicotine Vapes', description: 'A wide selection of nicotine vapes and disposables in popular brands and flavors. Ask our staff for the latest arrivals.', tag: null, icon: '🔋' },
  { name: 'Glass', description: 'Quality glass pieces for every preference and budget. Pipes, bubblers, and more — always a fresh selection in store.', tag: null, icon: '🫧' },
  { name: 'Flower Accessories', description: 'Everything you need to enjoy your flower. Rolling papers, grinders, trays, and more.', tag: null, icon: '🌀' },
  { name: 'Lifestyle & Exotic Items', description: "A rotating selection of unique exotic products that elevate your everyday. Come in to see what's new.", tag: 'Always New', icon: '🛍️' },
];
---

<Layout title="Products" description="Browse ICT Exoticz's selection of hemp-derived cannabinoids, accessories, and exotic lifestyle products in Wichita, KS.">

  <div class="page-header">
    <div class="container">
      <span class="section-label">Product Catalog</span>
      <h1>Our Products</h1>
      <p>Browse what we carry — then stop by any location to see the full selection and shop in person.</p>
      <div class="instore-notice">
        <span class="instore-icon">🏪</span>
        <span>All products are available <strong>in-store only</strong> — no online ordering at this time.</span>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="cat-header">
        <div>
          <span class="section-label">Lab-Tested · Hemp-Derived</span>
          <h2>Hemp-Derived Cannabinoids</h2>
          <div class="divider"></div>
        </div>
        <span class="age-badge">21+ Only</span>
      </div>
      <div class="product-grid">
        {cannabinoidProducts.map(p => (
          <div class="glass-card product-card">
            <div class="product-icon">{p.icon}</div>
            {p.tag && <span class="tag">{p.tag}</span>}
            <h3>{p.name}</h3>
            <p>{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section lifestyle-section">
    <div class="container">
      <span class="section-label">Vapes · Glass · Accessories · Lifestyle</span>
      <h2>Accessories & More</h2>
      <div class="divider"></div>
      <div class="product-grid lifestyle-grid">
        {lifestyleProducts.map(p => (
          <div class="glass-card product-card">
            <div class="product-icon">{p.icon}</div>
            {p.tag && <span class="tag teal-tag">{p.tag}</span>}
            <h3>{p.name}</h3>
            <p>{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="glass-card visit-card">
        <div class="visit-inner">
          <div>
            <h2>Come See Us In-Store</h2>
            <p>Our inventory is always evolving. Visit any of our three locations to see the full selection and get personalized recommendations.</p>
          </div>
          <a href={`${base}contact`} class="btn btn-primary">Find a Location</a>
        </div>
      </div>
    </div>
  </section>

  <div class="disclaimer-bar">
    <div class="container">
      <p>Hemp-derived products are sold in compliance with the 2018 Farm Bill. Products contain less than 0.3% Delta-9 THC on a dry weight basis. These statements have not been evaluated by the Food and Drug Administration. Not intended to diagnose, treat, cure, or prevent any disease. Must be 21+.</p>
    </div>
  </div>

</Layout>

<style>
  .section { padding-block: 4.5rem; }

  .cat-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .age-badge {
    font-family: 'Rubik', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--danger);
    border: 1.5px solid var(--danger);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    align-self: flex-start;
    margin-top: 0.5rem;
    white-space: nowrap;
  }

  .product-icon {
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .lifestyle-grid { grid-template-columns: repeat(4, 1fr); }

  .product-card { padding: 2rem; }
  .product-card h3 { margin-bottom: 0.6rem; }
  .product-card p  { font-size: 0.9rem; line-height: 1.65; }

  .tag {
    display: inline-block;
    font-family: 'Rubik', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(6,182,212,0.3);
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
    margin-bottom: 0.85rem;
  }

  .teal-tag {
    color: #2DD4BF;
    background: rgba(20, 184, 166, 0.1);
    border-color: rgba(20, 184, 166, 0.3);
  }

  .lifestyle-section { padding-block: 4.5rem; }

  .visit-card { padding: 2.5rem; }
  .visit-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .visit-inner > div { max-width: 520px; }
  .visit-inner h2 { margin-bottom: 0.5rem; }

  .instore-notice {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    background: rgba(6,182,212,0.08);
    border: 1px solid rgba(6,182,212,0.25);
    border-radius: var(--radius-sm);
    padding: 0.6rem 1rem;
    font-size: 0.85rem;
    color: var(--text-2);
  }
  .instore-icon { font-size: 1rem; }

  .disclaimer-bar {
    padding-block: 1.5rem;
    border-top: 1px solid var(--glass-border);
  }
  .disclaimer-bar p { font-size: 0.78rem; color: var(--text-3); }

  @media (max-width: 1100px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 900px) {
    .lifestyle-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .lifestyle-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 540px) {
    .product-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .visit-inner { flex-direction: column; align-items: flex-start; }
    .visit-inner .btn { width: 100%; justify-content: center; }
  }
</style>
