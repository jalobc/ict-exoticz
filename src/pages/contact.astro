---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with ICT Exoticz in Wichita, KS. Two locations, phone numbers, and social media.">

  <div class="page-header">
    <div class="container">
      <span class="section-label">Get In Touch</span>
      <h1>Contact Us</h1>
      <p>Have a question? Reach out to us or stop by one of our Wichita locations.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">

      <div class="contact-grid">

        <!-- ICT Exoticz Broadway -->
        <div class="contact-card">
          <div class="card-top">
            <h2>ICT Exoticz</h2>
            <span class="loc-badge">Broadway</span>
          </div>

          <div class="contact-detail">
            <span class="detail-label">Address</span>
            <address>
              2837 N Broadway St #100<br />
              Wichita, KS 67219
            </address>
            <a
              href="https://www.google.com/maps/search/?api=1&query=2837+N+Broadway+St+%23100,+Wichita,+KS+67219"
              target="_blank"
              rel="noopener"
              class="map-link"
            >
              View on Google Maps &rarr;
            </a>
          </div>

          <div class="contact-detail">
            <span class="detail-label">Phone</span>
            <a href="tel:+13164131307" class="phone-num">(316) 413-1307</a>
          </div>

          <div class="contact-detail">
            <span class="detail-label">Hours</span>
            <ul class="hours-list">
              <li><span>Monday</span><span>4:20 PM – 8:00 PM</span></li>
              <li class="closed-row"><span>Tuesday</span><span>Closed</span></li>
              <li><span>Wednesday</span><span>4:20 PM – 8:00 PM</span></li>
              <li><span>Thursday</span><span>4:20 PM – 8:00 PM</span></li>
              <li><span>Friday</span><span>4:20 PM – 10:00 PM</span></li>
              <li><span>Saturday</span><span>1:00 PM – 10:00 PM</span></li>
              <li class="closed-row"><span>Sunday</span><span>Closed</span></li>
            </ul>
          </div>

          <div class="contact-detail">
            <span class="detail-label">Social</span>
            <a href="https://www.facebook.com/p/ICT-Exoticz-61554037832230/" target="_blank" rel="noopener" class="social-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook – ICT Exoticz
            </a>
          </div>
        </div>

        <!-- ICT Exoticz 2 Seneca -->
        <div class="contact-card">
          <div class="card-top">
            <h2>ICT Exoticz 2</h2>
            <span class="loc-badge">Seneca</span>
          </div>

          <div class="contact-detail">
            <span class="detail-label">Address</span>
            <address>
              3125 S Seneca St<br />
              Wichita, KS 67217
            </address>
            <a
              href="https://www.google.com/maps/search/?api=1&query=3125+S+Seneca+St,+Wichita,+KS+67217"
              target="_blank"
              rel="noopener"
              class="map-link"
            >
              View on Google Maps &rarr;
            </a>
          </div>

          <div class="contact-detail">
            <span class="detail-label">Phone</span>
            <a href="tel:+13163122515" class="phone-num">(316) 312-2515</a>
          </div>

          <div class="contact-detail">
            <span class="detail-label">Email</span>
            <a href="mailto:ictexoticz2@yahoo.com" class="email-link">ictexoticz2@yahoo.com</a>
          </div>

          <div class="contact-detail">
            <span class="detail-label">Hours</span>
            <ul class="hours-list">
              <li><span>Monday – Saturday</span><span>10:00 AM – 8:00 PM</span></li>
              <li><span>Sunday</span><span>12:00 PM – 8:00 PM</span></li>
            </ul>
          </div>

          <div class="contact-detail">
            <span class="detail-label">Social</span>
            <a href="https://www.facebook.com/p/ICT-Exoticz-2-61572496577319/" target="_blank" rel="noopener" class="social-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook – ICT Exoticz 2
            </a>
          </div>
        </div>
      </div>

      <!-- Instagram -->
      <div class="instagram-banner">
        <div class="ig-content">
          <div>
            <h3>Follow on Instagram</h3>
            <p>Stay up to date with new products, promotions, and announcements.</p>
          </div>
          <a href="https://www.instagram.com/ictexoticz/" target="_blank" rel="noopener" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            @ictexoticz
          </a>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  .section { padding-block: 4rem 5rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .contact-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: border-color 0.2s;
  }
  .contact-card:hover { border-color: var(--border-light); }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .loc-badge {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    background: var(--gold-glow);
    border: 1px solid var(--gold);
    padding: 0.25rem 0.65rem;
    border-radius: 100px;
  }

  .contact-detail {
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
  }

  .detail-label {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 0.5rem;
  }

  .contact-detail address {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .map-link {
    font-size: 0.85rem;
    color: var(--accent-light);
    font-family: 'Oswald', sans-serif;
    letter-spacing: 0.04em;
  }
  .map-link:hover { color: var(--gold-light); }

  .phone-num {
    font-family: 'Oswald', sans-serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-1);
    transition: color 0.15s;
  }
  .phone-num:hover { color: var(--accent-light); }

  .email-link {
    font-size: 0.95rem;
    color: var(--text-2);
  }
  .email-link:hover { color: var(--accent-light); }

  .hours-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hours-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.875rem;
  }
  .hours-list li:last-child { border-bottom: none; }
  .hours-list li span:first-child { color: var(--text-1); font-weight: 500; }
  .hours-list li span:last-child { color: var(--text-2); }

  .closed-row span { color: var(--text-3) !important; }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-2);
    transition: color 0.15s;
  }
  .social-link:hover { color: var(--accent-light); }

  /* Instagram banner */
  .instagram-banner {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 2rem 2.5rem;
    margin-top: 0.5rem;
  }

  .ig-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .ig-content h3 { margin-bottom: 0.3rem; }
  .ig-content p { font-size: 0.9rem; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .ig-content { flex-direction: column; align-items: flex-start; }
    .ig-content .btn { width: 100%; justify-content: center; }
  }
</style>
