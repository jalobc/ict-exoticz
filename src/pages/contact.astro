---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with ICT Exoticz in Wichita, KS. Three locations, phone numbers, and social media.">

  <div class="page-header">
    <div class="container">
      <span class="section-label">Get In Touch</span>
      <h1>Contact Us</h1>
      <p>Have a question? Reach out to us or stop by one of our three Wichita locations.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <div class="glass-card contact-card">
          <div class="card-top">
            <h2>ICT Exoticz</h2>
            <span class="loc-badge">Central Ave</span>
          </div>
          <div class="contact-detail">
            <h4>Address</h4>
            <address>2001 E Central Ave<br />Wichita, KS 67214</address>
            <a href="https://www.google.com/maps/search/?api=1&query=2001+E+Central+Ave,+Wichita,+KS+67214" target="_blank" rel="noopener" class="map-link">View on Google Maps &rarr;</a>
          </div>
          <div class="map-embed">
            <iframe
              title="ICT Exoticz location map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3144.8!2d-97.298!3d37.694!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87bae4b6b6b6b6b7%3A0x0!2s2001+E+Central+Ave%2C+Wichita%2C+KS+67214!5e0!3m2!1sen!2sus!4v1"
              width="100%" height="180" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
          <div class="contact-detail">
            <h4>Phone</h4>
            <a href="tel:+13164945534" class="phone-num">(316) 494-5534</a>
          </div>
          <div class="contact-detail">
            <h4>Hours</h4>
            <ul class="hours-list">
              <li><span>Monday</span><span class="closed">Closed</span></li>
              <li><span>Tuesday – Sunday</span><span>12:00 PM – 8:00 PM</span></li>
            </ul>
          </div>
        </div>

        <div class="glass-card contact-card">
          <div class="card-top">
            <h2>ICT Exoticz 2</h2>
            <span class="loc-badge">Seneca</span>
          </div>
          <div class="contact-detail">
            <h4>Address</h4>
            <address>3125 S Seneca St<br />Wichita, KS 67217</address>
            <a href="https://www.google.com/maps/search/?api=1&query=3125+S+Seneca+St,+Wichita,+KS+67217" target="_blank" rel="noopener" class="map-link">View on Google Maps &rarr;</a>
          </div>
          <div class="map-embed">
            <iframe
              title="ICT Exoticz 2 location map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3147.2!2d-97.358!3d37.647!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87bae5c5c5c5c5c5%3A0x0!2s3125+S+Seneca+St%2C+Wichita%2C+KS+67217!5e0!3m2!1sen!2sus!4v1"
              width="100%" height="180" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
          <div class="contact-detail">
            <h4>Phone</h4>
            <a href="tel:+13163122515" class="phone-num">(316) 312-2515</a>
          </div>
          <div class="contact-detail">
            <h4>Email</h4>
            <a href="mailto:ictexoticz2@yahoo.com" class="email-link">ictexoticz2@yahoo.com</a>
          </div>
          <div class="contact-detail">
            <h4>Hours</h4>
            <ul class="hours-list">
              <li><span>Monday – Saturday</span><span>10:00 AM – 10:00 PM</span></li>
              <li><span>Sunday</span><span>12:00 PM – 10:00 PM</span></li>
            </ul>
          </div>
          <div class="contact-detail">
            <h4>Social</h4>
            <a href="https://www.facebook.com/p/ICT-Exoticz-2-61572496577319/" target="_blank" rel="noopener" class="social-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook – ICT Exoticz 2
            </a>
          </div>
        </div>

        <div class="glass-card contact-card">
          <div class="card-top">
            <h2>ICT Exoticz 3</h2>
            <span class="loc-badge">Sweetbriar</span>
          </div>
          <div class="contact-detail">
            <h4>Address</h4>
            <address>2020 W 21st St<br />Wichita, KS 67203</address>
            <a href="https://www.google.com/maps/search/?api=1&query=2020+W+21st+St,+Wichita,+KS+67203" target="_blank" rel="noopener" class="map-link">View on Google Maps &rarr;</a>
          </div>
          <div class="map-embed">
            <iframe
              title="ICT Exoticz 3 location map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3144.5!2d-97.373!3d37.700!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87bae3a3a3a3a3a3%3A0x0!2s2020+W+21st+St%2C+Wichita%2C+KS+67203!5e0!3m2!1sen!2sus!4v1"
              width="100%" height="180" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
          <div class="contact-detail">
            <h4>Phone</h4>
            <a href="tel:+13162459639" class="phone-num">(316) 245-9639</a>
          </div>
          <div class="contact-detail">
            <h4>Hours</h4>
            <ul class="hours-list">
              <li><span>Monday – Sunday</span><span>12:00 PM – 10:00 PM</span></li>
            </ul>
          </div>
        </div>

      </div>

      <div class="glass-card ig-banner">
        <div class="ig-inner">
          <div>
            <h3>Follow on Instagram</h3>
            <p>Stay up to date with new products, promotions, and announcements.</p>
          </div>
          <a href="https://www.instagram.com/ictexoticz/" target="_blank" rel="noopener" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            @ictexoticz
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section { padding-block: 4rem 5rem; }

  .contact-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-bottom: 1.25rem; }

  .contact-card { padding: 2.25rem; display: flex; flex-direction: column; gap: 1.5rem; }

  .card-top { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }

  .loc-badge {
    font-family: 'Rubik', sans-serif;
    font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent); background: var(--accent-dim);
    border: 1px solid rgba(56,189,248,0.3);
    padding: 0.25rem 0.65rem; border-radius: 100px;
  }

  .contact-detail { border-top: 1px solid var(--glass-border); padding-top: 1.25rem; }
  .contact-detail h4 { margin-bottom: 0.5rem; }

  .contact-detail address { font-size: 0.95rem; color: var(--text-2); line-height: 1.7; margin-bottom: 0.5rem; }

  .map-link { font-family: 'Rubik', sans-serif; font-size: 0.82rem; font-weight: 600; color: var(--accent); }
  .map-link:hover { color: var(--accent-hover); }

  .phone-num { font-family: 'Rubik', sans-serif; font-size: 1.55rem; font-weight: 700; color: var(--text-1); transition: color 0.15s; }
  .phone-num:hover { color: var(--accent); }

  .email-link { font-size: 0.95rem; color: var(--text-2); transition: color 0.15s; }
  .email-link:hover { color: var(--accent); }

  .hours-list { list-style: none; display: flex; flex-direction: column; }

  .hours-list li {
    display: flex; justify-content: space-between; align-items: center;
    gap: 1rem; padding: 0.45rem 0;
    border-bottom: 1px solid var(--glass-border);
    font-size: 0.875rem;
  }
  .hours-list li:last-child { border-bottom: none; }
  .hours-list li span:first-child { color: var(--text-1); font-weight: 500; }
  .hours-list li span:last-child { color: var(--text-2); }
  .hours-list li.c span { color: var(--text-3) !important; }
  .closed { color: var(--text-3) !important; }

  .map-embed {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--glass-border);
  }

  .map-embed iframe {
    display: block;
    filter: invert(90%) hue-rotate(180deg);
  }

  .social-link { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; color: var(--text-2); transition: color 0.15s; }
  .social-link:hover { color: var(--accent); }

  .ig-banner { padding: 2rem 2.5rem; }
  .ig-inner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .ig-inner h3 { margin-bottom: 0.3rem; }
  .ig-inner p  { font-size: 0.9rem; }

  @media (max-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .ig-inner { flex-direction: column; align-items: flex-start; }
    .ig-inner .btn { width: 100%; justify-content: center; }
  }
</style>
