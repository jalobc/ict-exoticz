---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AgeGate from '../components/AgeGate.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ICT Exoticz – Your go-to shop for hemp-derived cannabinoids and exotic lifestyle products in Wichita, KS.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/ict-exoticz/astronaut-3d.png" />
    <link rel="apple-touch-icon" href="/ict-exoticz/astronaut-3d.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&family=Nunito+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | ICT Exoticz</title>

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | ICT Exoticz`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/ict-exoticz/astronaut-3d.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "ICT Exoticz",
      "description": "Wichita's go-to shop for hemp-derived cannabinoids, exotic lifestyle products, nicotine vapes, glass, and accessories.",
      "url": "https://jalobc.github.io/ict-exoticz/",
      "logo": "https://jalobc.github.io/ict-exoticz/astronaut-3d.png",
      "sameAs": [
        "https://www.facebook.com/p/ICT-Exoticz-61554037832230/",
        "https://www.instagram.com/ictexoticz/"
      ],
      "location": [
        {
          "@type": "LocalBusiness",
          "name": "ICT Exoticz",
          "address": { "@type": "PostalAddress", "streetAddress": "2001 E Central Ave", "addressLocality": "Wichita", "addressRegion": "KS", "postalCode": "67214" },
          "telephone": "+13164945534",
          "openingHours": ["Tu-Su 12:00-20:00"]
        },
        {
          "@type": "LocalBusiness",
          "name": "ICT Exoticz 2",
          "address": { "@type": "PostalAddress", "streetAddress": "3125 S Seneca St", "addressLocality": "Wichita", "addressRegion": "KS", "postalCode": "67217" },
          "telephone": "+13163122515",
          "openingHours": ["Mo-Sa 10:00-22:00", "Su 12:00-22:00"]
        },
        {
          "@type": "LocalBusiness",
          "name": "ICT Exoticz 3",
          "address": { "@type": "PostalAddress", "streetAddress": "2020 W 21st St", "addressLocality": "Wichita", "addressRegion": "KS", "postalCode": "67203" },
          "telephone": "+13162459639",
          "openingHours": ["Mo-Su 12:00-22:00"]
        }
      ]
    })} />
  </head>
  <body>
    <AgeGate />
    <!-- Starfield Canvas -->
    <canvas id="starfield" aria-hidden="true"></canvas>

    <!-- Nebula layers -->
    <div class="nebula-layer" aria-hidden="true">
      <div class="nebula n1"></div>
      <div class="nebula n2"></div>
      <div class="nebula n3"></div>
      <div class="nebula n4"></div>
    </div>

    <!-- Announcement Banner -->
    <div id="announce-bar" class="announce-bar" role="banner" aria-label="Announcement">
      <span class="announce-text">🚀 New arrivals in store — stop by and check out what's new!</span>
      <button id="announce-close" class="announce-close" aria-label="Dismiss announcement">✕</button>
    </div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Back to Top -->
    <button id="back-to-top" class="back-to-top" aria-label="Back to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
    </button>
  </body>
</html>

<script>
  // ── Starfield ──
  const canvas = document.getElementById('starfield') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  interface Star {
    x: number; y: number; r: number;
    opacity: number; speed: number; phase: number;
  }

  let stars: Star[] = [];

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function initStars() {
    stars = [];
    const count = Math.floor((canvas.width * canvas.height) / 5000);
    for (let i = 0; i < count; i++) {
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        r: Math.random() * 1.4 + 0.2,
        opacity: Math.random() * 0.6 + 0.15,
        speed: Math.random() * 0.012 + 0.003,
        phase: Math.random() * Math.PI * 2,
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    stars.forEach(s => {
      s.phase += s.speed;
      const alpha = s.opacity * (0.65 + 0.35 * Math.sin(s.phase));
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(186, 220, 255, ${alpha})`;
      ctx.fill();
    });
    requestAnimationFrame(draw);
  }

  resize();
  initStars();
  draw();
  window.addEventListener('resize', () => { resize(); initStars(); });

  // ── Announcement banner ──
  const announceBar = document.getElementById('announce-bar');
  const announceClose = document.getElementById('announce-close');
  if (sessionStorage.getItem('announce_dismissed') === '1') {
    announceBar?.remove();
    document.documentElement.style.setProperty('--banner-h', '0px');
  }
  announceClose?.addEventListener('click', () => {
    sessionStorage.setItem('announce_dismissed', '1');
    announceBar?.classList.add('announce-exit');
    document.documentElement.style.setProperty('--banner-h', '0px');
    setTimeout(() => announceBar?.remove(), 300);
  });

  // ── Back to top ──
  const btt = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    btt?.classList.toggle('btt-visible', window.scrollY > 400);
  }, { passive: true });
  btt?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // ── Scroll animations ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>

<style is:global>
  /* ── Design Tokens ── */
  :root {
    --bg:           #050509;
    --bg-alt:       #08080e;

    /* Glass surfaces */
    --glass-bg:     rgba(255, 255, 255, 0.05);
    --glass-bg-2:   rgba(255, 255, 255, 0.09);
    --glass-bg-3:   rgba(255, 255, 255, 0.13);
    --glass-blur:   blur(32px) saturate(180%);
    --glass-border: rgba(255, 255, 255, 0.12);
    --glass-border-hover: rgba(6, 182, 212, 0.5);

    /* Accent – cyan (matches astronaut suit) */
    --accent:       #06B6D4;
    --accent-hover: #22D3EE;
    --accent-dim:   rgba(6, 182, 212, 0.12);
    --accent-glow:  rgba(6, 182, 212, 0.28);

    /* Nebula colors */
    --nebula-blue:   rgba(6, 182, 212, 0.13);
    --nebula-violet: rgba(139, 92, 246, 0.14);
    --nebula-teal:   rgba(20, 184, 166, 0.10);

    --text-1:       #EEF2FF;
    --text-2:       #8892B0;
    --text-3:       #4A5580;

    --danger:       #F87171;
    --success:      #34D399;

    --radius-sm:    8px;
    --radius-md:    16px;
    --radius-lg:    24px;

    --shadow-glass: 0 8px 32px rgba(0, 0, 0, 0.5);
    --shadow-glow:  0 0 30px rgba(6, 182, 212, 0.2);

    --max-w:        1200px;
    --nav-h:        68px;
    --banner-h:     38px;
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--bg);
    color: var(--text-1);
    font-family: 'Nunito Sans', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  main { flex: 1; padding-top: calc(var(--nav-h) + var(--banner-h)); }

  /* ── Starfield ── */
  #starfield {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Nebula ── */
  .nebula-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .nebula {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .n1 {
    width: 900px; height: 600px;
    background: var(--nebula-violet);
    top: -250px; right: -200px;
  }
  .n2 {
    width: 700px; height: 700px;
    background: var(--nebula-blue);
    top: 35%; left: -250px;
  }
  .n3 {
    width: 600px; height: 500px;
    background: var(--nebula-teal);
    bottom: 5%; right: 5%;
  }
  .n4 {
    width: 500px; height: 400px;
    background: var(--nebula-violet);
    top: 70%; left: 40%;
  }

  /* ── Ensure content is above background layers ── */
  header, main, footer { position: relative; z-index: 1; }

  /* ── Typography ── */
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Rubik', sans-serif;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--text-1);
  }

  h1 { font-size: clamp(2.2rem, 5vw, 3.6rem); text-shadow: 0 0 40px rgba(6,182,212,0.15); }
  h2 { font-size: clamp(1.6rem, 3.5vw, 2.4rem); }
  h3 { font-size: clamp(1.1rem, 2.5vw, 1.4rem); }
  h4 {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-3);
  }

  p { color: var(--text-2); line-height: 1.75; }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  a:hover { color: var(--accent-hover); }

  ul { list-style: none; }
  address { font-style: normal; }
  img { max-width: 100%; display: block; }

  /* ── Layout ── */
  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: clamp(1rem, 5vw, 2.5rem);
  }

  /* ── Section label ── */
  .section-label {
    display: inline-block;
    font-family: 'Rubik', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  /* ── Divider ── */
  .divider {
    width: 44px;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), transparent);
    border-radius: 2px;
    margin-block: 1rem;
  }

  /* ── Glass card ── */
  .glass-card {
    background: linear-gradient(135deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.03) 100%);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-glass), inset 0 1px 0 rgba(255,255,255,0.08);
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    position: relative;
    overflow: hidden;
  }
  .glass-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 60%);
    border-radius: inherit;
    pointer-events: none;
  }
  .glass-card:hover {
    border-color: var(--glass-border-hover);
    box-shadow: var(--shadow-glow), inset 0 1px 0 rgba(6,182,212,0.15);
    transform: translateY(-3px);
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'Rubik', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.7rem 1.6rem;
    border-radius: var(--radius-sm);
    border: none;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .btn:hover { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), #0891B2);
    color: #020617;
    box-shadow: 0 0 16px rgba(6,182,212,0.3);
  }
  .btn-primary:hover {
    background: linear-gradient(135deg, var(--accent-hover), var(--accent));
    box-shadow: 0 0 32px var(--accent-glow), 0 0 8px rgba(6,182,212,0.4);
    color: #020617;
  }

  .btn-outline {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    color: var(--text-1);
    border: 1px solid var(--glass-border);
  }
  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 16px var(--accent-dim);
  }

  /* ── Page header ── */
  .page-header {
    padding: 4.5rem 0 3rem;
    text-align: center;
    border-bottom: 1px solid var(--glass-border);
  }
  .page-header h1 { margin-bottom: 0.75rem; }
  .page-header p { font-size: 1.1rem; max-width: 540px; margin-inline: auto; }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: rgba(6,182,212,0.3); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

  /* ── Scroll animations ── */
  .fade-in {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .fade-in-delay-1 { transition-delay: 0.1s; }
  .fade-in-delay-2 { transition-delay: 0.2s; }
  .fade-in-delay-3 { transition-delay: 0.3s; }

  /* ── Focus ── */
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 3px;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
    #starfield { display: none; }
  }

  @media (max-width: 768px) {
    .page-header { padding: 3rem 1.5rem 2rem; }
  }

  /* ── Announcement Banner ── */
  .announce-bar {
    position: relative;
    z-index: 101;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.6rem 1.5rem;
    background: linear-gradient(90deg, rgba(6,182,212,0.15), rgba(6,182,212,0.08), rgba(6,182,212,0.15));
    border-bottom: 1px solid rgba(6,182,212,0.25);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .announce-text {
    font-family: 'Rubik', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-1);
    text-align: center;
  }
  .announce-close {
    background: none;
    border: none;
    color: var(--text-3);
    cursor: pointer;
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s;
    position: absolute;
    right: 1rem;
  }
  .announce-close:hover { color: var(--text-1); }
  .announce-exit { opacity: 0; transform: translateY(-100%); }

  /* ── Back to Top ── */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 99;
    width: 44px; height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--glass-bg-2);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 50%;
    color: var(--accent);
    cursor: pointer;
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease, border-color 0.15s, box-shadow 0.15s;
  }
  .back-to-top.btt-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .back-to-top:hover {
    border-color: var(--accent);
    box-shadow: 0 0 16px var(--accent-dim);
  }
</style>
