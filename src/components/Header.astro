---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/contact', label: 'Contact' },
];

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const baseNorm = base.replace(/\/$/, '');
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === base || currentPath === baseNorm || currentPath === baseNorm + '/';
  return currentPath === baseNorm + href || currentPath.startsWith(baseNorm + href + '/');
}
---

<header>
  <nav class="container">
    <a href={base} class="logo" aria-label="ICT Exoticz home">
      <img src={`${base}astronaut-3d.png`} alt="" class="logo-img" aria-hidden="true" width="56" height="56" />
      <span class="logo-ict">ICT</span><span class="logo-exoticz">Exoticz</span>
    </a>

    <div class="social-links">
      <a href="https://www.facebook.com/p/ICT-Exoticz-61554037832230/" target="_blank" rel="noopener" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
      <a href="https://www.instagram.com/ictexoticz/" target="_blank" rel="noopener" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </a>
    </div>

    <button class="menu-toggle" id="menuToggle" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="navMenu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul id="navMenu" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={`${base}${link.href === '/' ? '' : link.href}`}
            class:list={[{ active: isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menuToggle');
  const menu = document.getElementById('navMenu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.classList.toggle('active', isOpen ?? false);
  });
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.classList.remove('active');
    });
  });
</script>

<style>
  header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: var(--nav-h);
    background: rgba(5, 5, 9, 0.6);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border-bottom: 1px solid var(--glass-border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .logo {
    font-family: 'Rubik', sans-serif;
    font-size: 1.45rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo-img {
    width: 56px;
    height: 56px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(6, 182, 212, 0.6));
  }
  .logo-ict  { color: var(--accent); }
  .logo-exoticz { color: var(--text-1); }
  .logo:hover .logo-ict { color: var(--accent-hover); }

  ul {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
  }

  ul a {
    font-family: 'Rubik', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }
  ul a:hover {
    color: var(--text-1);
    background: var(--glass-bg-2);
  }
  ul a.active {
    color: var(--accent);
    background: var(--accent-dim);
  }
  ul a.active:hover {
    color: var(--accent-hover);
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--text-2);
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }

  .social-links a:hover {
    color: var(--accent);
    background: var(--glass-bg-2);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px; height: 44px;
    padding: 10px;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
  }
  .menu-toggle span {
    display: block;
    width: 22px; height: 2px;
    background: var(--text-1);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
    transform-origin: center;
  }
  .menu-toggle.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle.active span:nth-child(2) { opacity: 0; }
  .menu-toggle.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 640px) {
    .menu-toggle { display: flex; }
    ul {
      display: none;
      position: absolute;
      top: var(--nav-h); left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: rgba(5, 5, 9, 0.92);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
      border-bottom: 1px solid var(--glass-border);
      padding: 0.75rem;
    }
    ul.open { display: flex; }
    ul a { display: block; padding: 0.85rem 1rem; font-size: 1rem; }
  }
</style>
