---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/locations', label: 'Locations' },
  { href: '/contact', label: 'Contact' },
];

const base = import.meta.env.BASE_URL;
---

<header>
  <nav>
    <a href={base} class="logo">ICT Exoticz</a>
    <ul>
      {navLinks.map(link => (
        <li>
          <a href={`${base}${link.href === '/' ? '' : link.href}`}>{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>
