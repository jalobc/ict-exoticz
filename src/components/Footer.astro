---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer>
  <div class="footer-inner container">
    <div class="footer-brand">
      <a href={base} class="footer-logo">
        <span class="logo-ict">ICT</span><span class="logo-exoticz">Exoticz</span>
      </a>
      <p>Your go-to shop for hemp-derived cannabinoids and exotic lifestyle products in Wichita, KS.</p>
    </div>

    <div class="footer-col">
      <h4>Locations</h4>
      <ul>
        <li>
          <strong>ICT Exoticz</strong>
          2001 E Central Ave<br />Wichita, KS 67214<br />
          <a href="tel:+13164945534">(316) 494-5534</a>
        </li>
        <li>
          <strong>ICT Exoticz 2</strong>
          3125 S Seneca St<br />Wichita, KS 67217<br />
          <a href="tel:+13163122515">(316) 312-2515</a>
        </li>
        <li>
          <strong>ICT Exoticz 3</strong>
          2020 W 21st St<br />Wichita, KS 67203<br />
          <a href="tel:+13162459639">(316) 245-9639</a>
        </li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Quick Links</h4>
      <ul class="footer-links">
        <li><a href={`${base}`}>Home</a></li>
        <li><a href={`${base}products`}>Products</a></li>
        <li><a href={`${base}contact`}>Contact</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Follow Us</h4>
      <ul class="footer-links">
        <li><a href="https://www.facebook.com/p/ICT-Exoticz-61554037832230/" target="_blank" rel="noopener">Facebook – ICT Exoticz</a></li>
        <li><a href="https://www.facebook.com/p/ICT-Exoticz-2-61572496577319/" target="_blank" rel="noopener">Facebook – ICT Exoticz 2</a></li>
        <li><a href="https://www.instagram.com/ictexoticz/" target="_blank" rel="noopener">Instagram – @ictexoticz</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; {year} ICT Exoticz. All rights reserved. | Wichita, KS</p>
      <p class="disclaimer">Must be 21+ to purchase hemp-derived cannabinoid products. Not evaluated by the FDA. Not intended to diagnose, treat, cure, or prevent any disease.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: rgba(5, 5, 9, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--glass-border);
    margin-top: 5rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr 1fr;
    gap: 3rem;
    padding-top: 3.5rem;
    padding-bottom: 3rem;
  }

  .footer-logo {
    font-family: 'Syne', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .logo-ict   { color: var(--accent); }
  .logo-exoticz { color: var(--text-1); }

  .footer-brand p {
    font-size: 0.875rem;
    line-height: 1.65;
    max-width: 280px;
  }

  .footer-col h4 { margin-bottom: 1rem; }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-col ul li {
    font-size: 0.85rem;
    color: var(--text-2);
    line-height: 1.65;
  }

  .footer-col ul li strong {
    display: block;
    color: var(--text-1);
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--text-2);
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--accent); }

  .footer-bottom {
    border-top: 1px solid var(--glass-border);
    padding-block: 1.25rem;
  }

  .footer-bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .footer-bottom p { font-size: 0.78rem; color: var(--text-3); }
  .disclaimer { max-width: 580px; text-align: right; }

  @media (max-width: 900px) {
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 540px) {
    .footer-inner { grid-template-columns: 1fr; gap: 1.75rem; }
    .footer-bottom-inner { flex-direction: column; }
    .disclaimer { text-align: left; }
  }
</style>
